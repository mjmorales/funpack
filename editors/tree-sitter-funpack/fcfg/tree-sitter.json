{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "fcfg",
      "camelcase": "Fcfg",
      "scope": "source.fcfg",
      "path": ".",
      "file-types": ["fcfg"],
      "injection-regex": "^fcfg$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "funpack .fcfg config-layer grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/mjmorales/funpack"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
