{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "fun",
      "camelcase": "Fun",
      "scope": "source.fun",
      "path": ".",
      "file-types": ["fun"],
      "injection-regex": "^fun$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "funpack .fun language grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/mjmorales/funpack"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false
  }
}
