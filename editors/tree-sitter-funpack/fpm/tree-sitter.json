  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    { "name": "fpm", "camelcase": "Fpm", "scope": "source.fpm", "path": ".", "file-types": ["fpm"], "injection-regex": "^fpm$" }
