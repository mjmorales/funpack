{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "funpack-config",
  "scopeName": "source.fcfg",
  "patterns": [
    { "include": "#block-headers" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#booleans" },
    { "include": "#numbers" },
    { "include": "#assignment-key" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "block-headers": {
      "comment": "project/entrypoint/build NAME { … } — the label is the block's name.",
      "match": "\\b(project|entrypoint|build)\\s+([a-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.fcfg" },
        "2": { "name": "entity.name.namespace.fcfg" }
      }
    },
    "keywords": {
      "patterns": [
        { "match": "\\b(project|entrypoint|build|tags|use)\\b", "name": "keyword.control.fcfg" },
        { "match": "\\b(version|path|url|hash)\\b", "name": "keyword.other.dep.fcfg" }
      ]
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.fcfg",
      "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.fcfg" }]
    },
    "booleans": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.fcfg"
    },
    "numbers": {
      "patterns": [
        { "match": "\\b[0-9]+x[0-9]+\\b", "name": "constant.numeric.resolution.fcfg" },
        { "match": "\\b[0-9]+hz\\b", "name": "constant.numeric.tickrate.fcfg" },
        { "match": "\\b[0-9]+\\b", "name": "constant.numeric.integer.fcfg" }
      ]
    },
    "assignment-key": {
      "comment": "lower_ident before '=' is a config key.",
      "match": "\\b([a-z_][A-Za-z0-9_]*)(?=\\s*=)",
      "name": "variable.other.property.fcfg"
    },
    "types": {
      "comment": "UpperCamel name refs (pipeline names, variant heads).",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
      "name": "entity.name.type.fcfg"
    },
    "operators": {
      "match": "(::|=|\\.)",
      "name": "keyword.operator.fcfg"
    },
    "punctuation": {
      "patterns": [
        { "match": "[(){}]", "name": "punctuation.section.brackets.fcfg" },
        { "match": ",", "name": "punctuation.separator.fcfg" }
      ]
    }
  }
}
