#!/usr/bin/env bash
# funpack-mcp plugin launcher — selects a funpack-mcp binary and execs it. This is
# the `command` the plugin's .mcp.json invokes; Claude Code expands
# ${CLAUDE_PLUGIN_ROOT} to the plugin install dir, so the declared command is
# ${CLAUDE_PLUGIN_ROOT}/bin/funpack-mcp — this file.
#
# Resolution order (three sources, first hit wins):
#   1. $CLAUDE_PLUGIN_DATA/bin/funpack-mcp — the persistent, update-surviving binary
#      the `funpack:funpack-mcp install` skill fetches. ${CLAUDE_PLUGIN_ROOT} is wiped on every
#      plugin update, but ${CLAUDE_PLUGIN_DATA} (~/.claude/plugins/data/<plugin-id>/)
#      persists and is exported to this child process, so we prefer it.
#   2. $dir/funpack-mcp-<os>-<arch> — a per-platform binary bundled beside this wrapper
#      by `task mcp:bundle` (dev/cross-compile path). Gitignored; the wrapper is committed.
#   3. funpack-mcp on PATH — a brew / `go install` build for dev.
#
# Windows is out of scope — the funpack toolchain is unix-centric, so only darwin and
# linux are mapped.
set -euo pipefail

dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"

# 1. Persistent, skill-installed binary (survives plugin updates).
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ] && [ -x "${CLAUDE_PLUGIN_DATA}/bin/funpack-mcp" ]; then
  exec "${CLAUDE_PLUGIN_DATA}/bin/funpack-mcp" "$@"
fi

case "$(uname -s)" in
  Darwin) os=darwin ;;
  Linux)  os=linux ;;
  *)
    echo "funpack-mcp: unsupported OS $(uname -s) (darwin and linux only)" >&2
    exit 1
    ;;
esac

case "$(uname -m)" in
  arm64 | aarch64) arch=arm64 ;;
  x86_64 | amd64)  arch=amd64 ;;
  *)
    echo "funpack-mcp: unsupported arch $(uname -m) (arm64 and amd64 only)" >&2
    exit 1
    ;;
esac

# 2. Per-platform binary bundled beside this wrapper (dev / task mcp:bundle).
bundled="$dir/funpack-mcp-$os-$arch"
if [ -x "$bundled" ]; then
  exec "$bundled" "$@"
fi

# 3. Dev / go-install fallback: a real funpack-mcp server on PATH — but NEVER this
# wrapper. If the plugin bin dir (or a symlink) puts this file on PATH, `command -v`
# resolves to the wrapper itself and exec'ing it would loop forever, re-entering here
# every iteration. `-ef` compares device+inode (following symlinks), so a self-hit is
# skipped and we fall through to the install hint below rather than spin.
if cand="$(command -v funpack-mcp 2>/dev/null)" && [ -n "$cand" ] && ! [ "$cand" -ef "${BASH_SOURCE[0]}" ]; then
  exec "$cand" "$@"
fi

echo "funpack-mcp: no funpack-mcp binary found — run the \`funpack:funpack-mcp install\` skill (or \`task mcp:bundle\` for a dev build)" >&2
exit 1
