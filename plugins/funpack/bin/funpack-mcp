#!/usr/bin/env bash
# funpack-mcp plugin launcher — selects a funpack-mcp server binary and execs it.
# This is the `command` the plugin's .mcp.json invokes; Claude Code expands
# ${CLAUDE_PLUGIN_ROOT} to the plugin install dir, so the declared command is
# ${CLAUDE_PLUGIN_ROOT}/bin/funpack-mcp — this file.
#
# Resolution order (three sources, first hit wins):
#   1. $dir/funpack-mcp-<os>-<arch> — the per-platform binary bundled beside this
#      wrapper in the published plugin. It ALWAYS matches the installed plugin version
#      (the cache is replaced wholesale on every plugin update), so it is preferred:
#      a stale one-time `funpack:funpack-mcp install` in the data dir can no longer
#      shadow a fresher bundle. (This deliberately reverses an earlier data-dir-first
#      order — do not flip it back: with the binary bundled into every release, the
#      bundle is the current build and the data-dir copy is only a fallback.)
#   2. $CLAUDE_PLUGIN_DATA/bin/funpack-mcp — the persistent, update-surviving binary
#      the `funpack:funpack-mcp install` skill fetches. The fallback for a platform
#      with no bundled binary; ${CLAUDE_PLUGIN_DATA} survives the cache wipe a plugin
#      update performs on ${CLAUDE_PLUGIN_ROOT}.
#   3. funpack-mcp on PATH — a brew / `go install` build for dev.
#
# Windows is out of scope — the funpack toolchain is unix-centric, so only darwin and
# linux are mapped.
set -euo pipefail

# Compiler discovery is the server's resolver's job (PATH + the standard install
# locations), NOT this wrapper's: the .mcp.json ships no FUNPACK_BIN, so the var is
# unset unless a user explicitly exports an absolute override. Defensively drop a
# value that arrived as an unexpanded literal (e.g. a launcher that does not
# interpolate "${FUNPACK_BIN}" in an env block) so the resolver does its own search
# instead of treating the literal string as a path. A real override is preserved.
case "${FUNPACK_BIN:-}" in
  *'${'*) unset FUNPACK_BIN ;;
esac

dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd -P)"

case "$(uname -s)" in
  Darwin) os=darwin ;;
  Linux)  os=linux ;;
  *)
    echo "funpack-mcp: unsupported OS $(uname -s) (darwin and linux only)" >&2
    exit 1
    ;;
esac

case "$(uname -m)" in
  arm64 | aarch64) arch=arm64 ;;
  x86_64 | amd64)  arch=amd64 ;;
  *)
    echo "funpack-mcp: unsupported arch $(uname -m) (arm64 and amd64 only)" >&2
    exit 1
    ;;
esac

# 1. Per-platform binary bundled beside this wrapper — matches the installed plugin
#    version exactly, refreshed on every plugin update.
bundled="$dir/funpack-mcp-$os-$arch"
if [ -x "$bundled" ]; then
  exec "$bundled" "$@"
fi

# 2. Persistent, skill-installed binary — the fallback for an unbundled platform.
if [ -n "${CLAUDE_PLUGIN_DATA:-}" ] && [ -x "${CLAUDE_PLUGIN_DATA}/bin/funpack-mcp" ]; then
  exec "${CLAUDE_PLUGIN_DATA}/bin/funpack-mcp" "$@"
fi

# 3. Dev / go-install fallback: a real funpack-mcp server on PATH — but NEVER this
# wrapper. If the plugin bin dir (or a symlink) puts this file on PATH, `command -v`
# resolves to the wrapper itself and exec'ing it would loop forever, re-entering here
# every iteration. `-ef` compares device+inode (following symlinks), so a self-hit is
# skipped and we fall through to the install hint below rather than spin.
if cand="$(command -v funpack-mcp 2>/dev/null)" && [ -n "$cand" ] && ! [ "$cand" -ef "${BASH_SOURCE[0]}" ]; then
  exec "$cand" "$@"
fi

echo "funpack-mcp: no funpack-mcp binary found — run the \`funpack:funpack-mcp install\` skill (or \`task mcp:bundle\` for a dev build)" >&2
exit 1
