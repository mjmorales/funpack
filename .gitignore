.prove/
.claude-env

# build output — the single consolidated binary, built into its entry package dir
# by `task binary` / `task cmd:binary`.
cmd/funpack/funpack

# §14 derived build products — gitignored, rebuilt on demand
.funpack/

# machine-local symlinks (written by claude-prove install init/local-env)
.claude/prove-plugin

# live sub-task worktrees (claude-prove worktree create)
.claude/worktrees/

# live-session outputs beside the testdata artifacts (regenerable by playing;
# committed goldens are *_golden.replay / *_golden.digest and stay tracked)
runtime/testdata/*.replay
!runtime/testdata/*_golden.replay
runtime/testdata/*.saves/
.prove-wt-slug.txt
