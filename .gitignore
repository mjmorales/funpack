.prove/
.claude-env

# build output — the single consolidated binary, built into its entry package dir
# by `task binary` / `task cmd:binary`.
cmd/funpack/funpack

# stray ad-hoc compiled binaries at the repo root (e.g. odin build . -out:funpack.bin)
/funpack.bin

# §14 derived build products — gitignored, rebuilt on demand
.funpack/

# inspect_screenshot capture dir (default output; override with FUNPACK_SCREENSHOT_DIR)
.funpack-mcp/

# machine-local symlinks (written by claude-prove install init/local-env)
.claude/prove-plugin

# live sub-task worktrees (claude-prove worktree create)
.claude/worktrees/

# live-session outputs beside the testdata artifacts (regenerable by playing;
# committed goldens are *_golden.replay / *_golden.digest and stay tracked)
runtime/testdata/*.replay
!runtime/testdata/*_golden.replay
runtime/testdata/*.saves/
.prove-wt-slug.txt

# dogfood friction log — local-only findings, bubbled into scrum (upstream: tracked:<id>)
# by the friction skill; the scrum tasks are the durable record, not these files.
# Root-anchored: must NOT match .claude/skills/friction/ (the tracked skill).
/friction/
