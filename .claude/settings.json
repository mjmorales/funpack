{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "claude-prove acb hook post-commit --workspace-root $CLAUDE_PROJECT_DIR",
            "timeout": 10000
          }
        ],
        "_tool": "acb"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook validate",
            "timeout": 5000
          }
        ],
        "_tool": "run_state"
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook capture",
            "timeout": 5000
          }
        ],
        "_tool": "run_state"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove cafi gate",
            "timeout": 10000
          }
        ],
        "_tool": "cafi"
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook guard",
            "timeout": 5000
          }
        ],
        "_tool": "run_state"
      },
      {
        "matcher": "Read|Write|Edit|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook bounds",
            "timeout": 5000
          }
        ],
        "_tool": "run_state"
      }
    ],
    "SessionStart": [
      {
        "matcher": "resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook session-start",
            "timeout": 3000
          }
        ],
        "_tool": "run_state"
      },
      {
        "matcher": "startup|resume|compact",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove scrum hook session-start",
            "timeout": 3000
          }
        ],
        "_tool": "scrum"
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook stop",
            "timeout": 5000
          }
        ],
        "_tool": "run_state"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove scrum hook stop",
            "timeout": 3000
          }
        ],
        "_tool": "scrum"
      }
    ],
    "SubagentStop": [
      {
        "matcher": "general-purpose",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove run-state hook subagent-stop",
            "timeout": 5000
          }
        ],
        "_tool": "run_state"
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "claude-prove scrum hook subagent-stop",
            "timeout": 5000
          }
        ],
        "_tool": "scrum"
      }
    ]
  }
}
