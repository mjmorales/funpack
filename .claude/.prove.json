{
  "schema_version": "12",
  "dev_mode": false,
  "artifacts": {
    "html_open": "open {file}"
  },
  "scopes": {
    "funpack": "funpack/",
    "runtime": "runtime/",
    "mcp": "mcp/",
    "eir": "cmd/eir/",
    "teams": "teams/",
    "contributors": "contributors/",
    "config": ".claude/"
  },
  "validators": [
    {
      "name": "build",
      "command": "task build",
      "phase": "build"
    },
    {
      "name": "lint",
      "command": "task lint",
      "phase": "lint"
    },
    {
      "name": "tests",
      "command": "task test",
      "phase": "test"
    },
    {
      "name": "comment-audit",
      "skill": "claude-skills:comment-audit",
      "phase": "llm"
    },
    {
      "name": "engine-api-doc-parity",
      "prompt": "ci/prompts/engine-api-doc-parity.md",
      "phase": "llm"
    },
    {
      "name": "companion-doc-parity",
      "prompt": "ci/prompts/companion-doc-parity.md",
      "phase": "llm"
    }
  ],
  "reporters": [],
  "triggers": [
    {
      "on": "accepted",
      "workflow": "decompose",
      "description": "fire the next-layer decompose"
    },
    {
      "on": "blocked",
      "workflow": "re-plan",
      "description": "surface re-decomposition on a discovered dependency"
    }
  ],
  "claude_md": {
    "references": [
      {
        "path": "~/.claude-prove/latest/references/creator-conventions.md",
        "label": "Creator Conventions"
      },
      {
        "path": "~/.claude-prove/latest/references/interaction-patterns.md",
        "label": "Interaction Patterns"
      },
      {
        "path": "~/.claude-prove/latest/references/llm-coding-standards.md",
        "label": "LLM Coding Standards"
      },
      {
        "path": "docs/code-clarity.md",
        "label": "Code Clarity"
      },
      {
        "path": "~/.claude-prove/latest/references/prompt-engineering-guide.md",
        "label": "Prompt Engineering Guide"
      },
      {
        "path": "~/.claude-prove/latest/references/validation-config.md",
        "label": "Validation Config"
      },
      {
        "path": "~/.claude-prove/latest/references/passive-triggers.md",
        "label": "Passive Triggers"
      }
    ]
  },
  "tools": {
    "cafi": {
      "enabled": true,
      "config": {
        "excludes": [
          ".claude/worktrees/"
        ],
        "max_file_size": 204800
      }
    },
    "acb": {
      "enabled": false,
      "config": {
        "base_branch": "main"
      }
    },
    "pcd": {
      "enabled": true
    },
    "run_state": {
      "enabled": true
    },
    "scrum": {
      "enabled": true
    }
  },
  "brief": {
    "single_pass_token_threshold": 8000,
    "max_synthesis_retries": 2,
    "prose_judge_on": true
  },
  "memory": {
    "stale_threshold_days": 90
  },
  "decomposition": {
    "auto_accept_through": "none"
  }
}
